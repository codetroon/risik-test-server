NODE_ENV=development
PORT=5000

# Database (PostgreSQL / Neon)
DATABASE_URL=

# Auth
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=7d

# CORS — allowed frontend origin(s), comma-separated, no trailing slash
FRONTEND_ORIGIN=http://localhost:3000,https://risik-prn.vercel.app

# Cloudinary — document file storage (resource_type "raw")
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
